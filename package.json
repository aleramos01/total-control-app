{
  "name": "total-control-app-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "setup:front": "npm --prefix Front-end install",
    "setup:back": "npm --prefix backend install",
    "setup": "npm run setup:back && npm run setup:front",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres",
    "back:migrate": "npm --prefix backend run db:migrate",
    "back:seed": "npm --prefix backend run db:seed-demo",
    "back:bootstrap": "npm run back:migrate && npm run back:seed",
    "dev:front": "npm --prefix Front-end run dev",
    "dev:front:local": "npm run supabase:env && npm --prefix Front-end run dev",
    "dev:back": "npm --prefix backend run dev",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset",
    "supabase:status": "npx supabase status",
    "supabase:env": "node scripts/sync-supabase-env.mjs",
    "build:front": "npm --prefix Front-end run build",
    "build:back": "npm --prefix backend run build",
    "build": "npm run build:back && npm run build:front",
    "test:front": "npm --prefix Front-end run test",
    "test:back": "npm --prefix backend run test",
    "test": "npm run test:back && npm run test:front",
    "verify": "npm run test && npm run build"
  }
}
